# Live Transcription Demo example environment
#
# Copy to `.env` and adjust values for your machine.

# Backend application logging.
LTD_LOG_LEVEL=INFO

# Default ASR provider.
LTD_DEFAULT_ASR_PROVIDER=parakeet_unified

# Parakeet Unified runtime
# Required: point this at the local Parakeet Unified model artifact.
LTD_PARAKEET_MODEL_PATH=

# Recommended on this Mac: use the separate Python 3.12 NeMo env as the sidecar runtime.
LTD_PARAKEET_PYTHON_EXECUTABLE=/Users/habeeb/dev/repos/live-transcription-demo/.cache/nemo312/.venv/bin/python

# Buffered decode cadence for the local streaming path.
LTD_PARAKEET_MIN_AUDIO_SECS=1.6
LTD_PARAKEET_DECODE_HOP_SECS=1.6

# Optional NeMo fallback settings.
LTD_NEMO_MODEL_PATH=
LTD_NEMO_PYTHON_EXECUTABLE=
LTD_NEMO_MIN_AUDIO_SECS=1.6
LTD_NEMO_DECODE_HOP_SECS=1.6

# Backend-managed transcription defaults.
LTD_TRANSCRIPTION_LATENCY_PRESET=high_accuracy
LTD_TRANSCRIPTION_SEGMENTATION_POLICY=source_turns
LTD_TRANSCRIPTION_COACHING_WINDOW_POLICY=finalized_turns
LTD_TRANSCRIPTION_VAD_PROVIDER=silero_vad
LTD_TRANSCRIPTION_VAD_THRESHOLD=0.5
LTD_TRANSCRIPTION_VAD_MIN_SILENCE_MS=600

# Backend defaults for the coaching LLM.
# The desktop setup screen no longer exposes these values.
LTD_LLM_BASE_URL=http://localhost:11434/v1
LTD_LLM_MODEL=local-model
LTD_LLM_API_KEY=
LTD_LLM_TIMEOUT=30.0

# Optional: override the backend host/port that the Electron shell connects to.
# LTD_BACKEND_URL=http://127.0.0.1:8000
